# Vision-RCP Environment Template
# Copy this to .env and fill in the values

# --- Relay Configuration ---
# Secret token for daemon-to-relay authentication
RELAY_ACCESS_TOKEN=VISION_DEV_TOKEN_CHANGE_ME

# --- Daemon Configuration ---
# URL of the dashboard for mobile pairing links
VITE_DASHBOARD_URL=http://localhost:5173

# Outbound relay settings
RELAY_URL=http://localhost:8080
RELAY_TOKEN=VISION_DEV_TOKEN_CHANGE_ME

# --- UI Configuration (Vercel) ---
# The public websocket URL for the relay
VITE_RELAY_WS_URL=ws://localhost:8080/ws/client
